# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SendGrid (for api/send-email.js)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=daily@latinsecurities.ar

# Static PIN that gates POST /api/send-email. Required.
SEND_EMAIL_PIN=set-a-strong-random-pin

# Comma-separated list of origins allowed to call the API cross-origin.
# Leave empty to only allow same-origin (recommended for internal-only tools).
# Example: CORS_ALLOWED_ORIGINS=https://dailyv1.vercel.app,https://daily.example.com
CORS_ALLOWED_ORIGINS=

# Alpha Vantage (optional fallback for prices)
ALPHA_VANTAGE_API_KEY=your-key-here

# Sentry error tracking (optional). Without this, ErrorBoundary still
# shows the recovery UI and logs to console — but errors won't ship
# anywhere you can see them. Get a DSN at https://sentry.io/.
VITE_SENTRY_DSN=
# Optional: tag events with a release identifier for git-aware diffing.
VITE_SENTRY_RELEASE=

# Upstash Redis credentials (optional). When set, /api/send-email rate-limits
# failed-PIN attempts to 10 per IP per 15 min, returning HTTP 429 once the
# budget is exhausted. Without these vars, the endpoint still works but
# doesn't throttle brute-force attempts. Provision via:
#   Vercel Dashboard → Storage → Marketplace → Upstash Redis (Free tier)
# Vercel's integration auto-injects these. The legacy KV_URL is no longer
# required since the @upstash/redis client is REST-only.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
