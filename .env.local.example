# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SendGrid (for api/send-email.js)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=daily@latinsecurities.ar

# Static PIN that gates POST /api/send-email. Required.
SEND_EMAIL_PIN=set-a-strong-random-pin

# Comma-separated list of origins allowed to call the API cross-origin.
# Leave empty to only allow same-origin (recommended for internal-only tools).
# Example: CORS_ALLOWED_ORIGINS=https://dailyv1.vercel.app,https://daily.example.com
CORS_ALLOWED_ORIGINS=

# Alpha Vantage (optional fallback for prices)
ALPHA_VANTAGE_API_KEY=your-key-here
